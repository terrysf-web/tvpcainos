rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isLeader() {
      return isAuthed() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["leader", "admin"];
    }

    function isAdmin() {
      return isAuthed() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isFoh() {
      let ud = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isAuthed() && (
        ud.role in ["foh", "FOH", "admin"] ||
        ud.get("parts", []).hasAny(["FOH", "foh"])
      );
    }

    match /songs/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isLeader();
    }

    match /services/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isLeader();
    }

    match /notifications/{id} {
      allow read: if isAuthed();
      allow create: if isLeader();
      allow update: if isAuthed() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
    }

    match /annotations/{id} {
      allow read: if isAuthed() && (resource.data.userId == request.auth.uid || resource.data.shared == true);
      allow delete: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthed() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.auth.uid == userId;
      allow update: if isAuthed(); // 허용된 이메일만 로그인 가능하므로 인증된 사용자 전체 허용
      allow delete: if isAdmin();
    }

    // 허용 이메일: 읽기 인증된 모두(신규 가입 체크), 쓰기 어드민만
    match /allowedEmails/{email} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // 기존 컬렉션 유지
    match /customSongs/{document=**} {
      allow read, write: if isAuthed();
    }

    match /pdfFiles/{document=**} {
      allow read, write: if isAuthed();
    }

    match /songLyrics/{document=**} {
      allow read, write: if isAuthed();
    }

    match /userAnnotations/{userId}/{document=**} {
      allow read, write: if isAuthed() && request.auth.uid == userId;
    }

    // doc id = "{uid}_{songId}_p{page}" — 앱이 자신의 UID 포함 ID만 쿼리하므로 다른 사람 필기 안 보임
    match /userDrawings/{drawingId} {
      allow read, write: if isAuthed();
    }

    match /teamSettings/{document=**} {
      allow read, write: if isAuthed();
    }

    // 앱 설정 — 읽기 인증된 모두, fohMessages는 FOH/어드민 쓰기, 나머지 어드민만
    match /settings/fohMessages {
      allow read: if isAuthed();
      allow write: if isFoh();
    }
    match /settings/{docId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // AI 분석 결과 — 인증된 모든 팀원이 읽기/쓰기 가능
    match /songAnalysis/{songId} {
      allow read, write: if isAuthed();
    }

    // 액세스 신청 — 누구나 create, 리더/어드민만 read·delete
    match /accessRequests/{email} {
      allow create: if true;
      allow read, delete: if isLeader();
    }

    // ProPresenter 가사 — 리더가 쓰고 방송팀 포함 인증된 모두가 읽기
    match /ppLyrics/{svcId} {
      allow read: if isAuthed();
      allow write: if isLeader();
    }

    // LIVE 예배 세션 — 읽기 인증된 모두, 쓰기 리더/어드민
    match /liveSession/{svcId} {
      allow read: if isAuthed();
      allow write: if isLeader();
    }

    // LIVE 전체 상태 (방송팀 탭 표시 여부) — 읽기 인증된 모두, 쓰기 리더/FOH/어드민
    match /liveStatus/{docId} {
      allow read: if isAuthed();
      allow write: if isLeader() || isFoh();
    }

    // LIVE 팀 CUE — 인증된 모두 읽기/쓰기 (팀원이 자기 상태 업데이트)
    match /liveCues/{svcId} {
      allow read, write: if isAuthed();
    }

    // LIVE 팀 채팅 — 인증된 모두 읽기/쓰기
    match /liveChat/{svcId} {
      allow read: if isAuthed();
    }

    // X32 믹서 상태 — Admin SDK가 쓰고, 인증된 모두 읽기
    match /x32/{docId} {
      allow read: if isAuthed();
      allow write: if false; // Admin SDK만 쓰기 (서버측 우회)
    }

    // 예배 녹음 — 읽기/쓰기 인증된 모두 (create), 수정/삭제 리더만
    match /worshipRecordings/{id} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update, delete: if isLeader();
    }

    // 큐 노트 — 인증된 모든 팀원 읽기/쓰기
    match /cueNotes/{id} {
      allow read, write: if isAuthed();
    }

    // FOH → 멤버 개별 메시지 (doc ID = 수신자 uid)
    match /fohMessages/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow write: if isLeader() || isFoh();
    }
  }
}
