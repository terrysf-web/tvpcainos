rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isLeader() {
      return isAuthed() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "leader";
    }

    // 악보: 읽기 전체, 쓰기 리더만
    match /songs/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isLeader();
    }

    // 예배 일정: 읽기 전체, 쓰기 리더만
    match /services/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isLeader();
    }

    // 알림: 읽기 전체, 생성 리더, 읽음 처리(readBy)는 모두 가능
    match /notifications/{id} {
      allow read: if isAuthed();
      allow create: if isLeader();
      allow update: if isAuthed() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
    }

    // 메모(악보 위 핀): 본인 것만
    match /annotations/{id} {
      allow read, delete: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthed() && resource.data.userId == request.auth.uid;
    }

    // 사용자 프로필: 읽기 전체, 본인 or 리더 쓰기
    match /users/{userId} {
      allow read: if isAuthed();
      allow create, update: if isAuthed() &&
        (request.auth.uid == userId || isLeader());
      allow delete: if isLeader();
    }
  }
}
