rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isLeader() {
      return isAuthed() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["leader", "admin"];
    }

    function isAdmin() {
      return isAuthed() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // 악보: 읽기 전체, 쓰기 리더/어드민
    match /songs/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isLeader();
    }

    // 예배 일정: 읽기 전체, 쓰기 리더/어드민
    match /services/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isLeader();
    }

    // 알림: 읽기 전체, 생성 리더/어드민, 읽음 처리는 모두
    match /notifications/{id} {
      allow read: if isAuthed();
      allow create: if isLeader();
      allow update: if isAuthed() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
    }

    // 메모: 본인 것만
    match /annotations/{id} {
      allow read, delete: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthed() && resource.data.userId == request.auth.uid;
    }

    // 사용자 프로필: 읽기 전체, 쓰기 본인 or 리더/어드민
    match /users/{userId} {
      allow read: if isAuthed();
      allow create, update: if isAuthed() &&
        (request.auth.uid == userId || isLeader());
      allow delete: if isAdmin();
    }

    // 허용 이메일 목록: 읽기 인증된 모두(신규 가입 체크용), 쓰기 어드민만
    match /allowedEmails/{email} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }
  }
}
