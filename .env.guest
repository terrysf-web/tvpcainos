# 친구 교회용(무료 테스트) 빌드 설정 — `npx vite build --mode guest` 로 빌드.
# 새 Firebase 프로젝트의 firebaseConfig 값으로 아래를 채우세요.
# (Firebase web apiKey는 공개값이라 저장소에 둬도 보안 문제 없음)
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MSG_SENDER_ID=
VITE_FB_APP_ID=
# 비용/장비 기능 숨김 (AI·PP7·X32 등)
VITE_GUEST=1
